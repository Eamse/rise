// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ==========================================
// User 테이블 (회원가입용)
// ==========================================
model User {
  id        Int        @id @default(autoincrement()) // 자동 증가 번호 (DB가 자동 생성)
  userId    String     @unique // 사용자 아이디 (중복 불가)
  email     String     @unique // 이메일 (중복 불가)
  password  String // 비밀번호 (암호화해서 저장)
  name      String // 이름
  company   String     @default("") // 회사명 (선택)
  phone     String     @default("") // 전화번호 (선택)
  createdAt DateTime   @default(now()) // 가입일 (자동 생성)
  CartItem  CartItem[]
  Order     Order[]
}

// ==========================================
// Product 테이블 (상품 관리)
// ==========================================
model Product {
  id              Int        @id @default(autoincrement()) // 자동 증가 번호
  name            String // 상품명
  category        String // 카테고리
  subcategory     String // 서브카테고리
  price           Int // 가격
  description     String // 상품 설명
  stock           Int        @default(0) // 재고 (기본값 0)
  createdAt       DateTime   @default(now()) // 등록일 (자동 생성)
  minorder        Int        @default(0) // 최소 주문
  imageUrl        String? // 상품 이미지 경로 (선택)
  detailImageUrls String? // 상품 상세 이미지 경로 (선택)
  CartItem        CartItem[]
}

// ==========================================
// CartItem 테이블 (장바구니)
// ==========================================
model CartItem {
  id        Int      @id @default(autoincrement())
  userId    String
  productId Int
  quantity  Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [userId])
  product   Product  @relation(fields: [productId], references: [id])
  @@unique([userId, productId])
}

// ==========================================
// Admin 테이블 (관리자 전용 - User 테이블과 완전 분리)
// ==========================================
model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique  // 관리자 아이디 (중복 불가)
  password  String            // bcrypt 암호화된 비밀번호
  name      String            // 관리자 표시명
  createdAt DateTime @default(now())
}

// ==========================================
// Order 테이블 (주문)
// ==========================================
model Order {
  id         Int         @id @default(autoincrement())
  userId     String                      // 주문자 아이디
  status     String      @default("pending") // pending / confirmed / shipped / done
  totalPrice Int                         // 총 결제 금액
  receiver   String                      // 수령인 이름
  phone      String                      // 연락처
  address    String                      // 배송지 주소
  memo       String?                     // 배송 메모 (선택)
  createdAt  DateTime    @default(now())
  items      OrderItem[]                 // 주문 상품 목록
  user       User        @relation(fields: [userId], references: [userId])
}

// ==========================================
// OrderItem 테이블 (주문 상품 스냅샷)
// 나중에 상품 정보가 바뀌어도 주문 당시 가격/이름을 보존
// ==========================================
model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int
  productId   Int
  productName String  // 주문 당시 상품명 스냅샷
  price       Int     // 주문 당시 단가 스냅샷
  quantity    Int
  order       Order   @relation(fields: [orderId], references: [id])
}
